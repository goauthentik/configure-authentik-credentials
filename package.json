{
  "name": "configure-authentik-credentials",
  "description": "Use this action to authenticate to an application protected by authentik using the JWT token generated by GitHub Actions.",
  "version": "1.0.1",
  "author": "authentik Team <hello@goauthentik.io>",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/goauthentik/configure-authentik-credentials",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goauthentik/configure-authentik-credentials.git"
  },
  "bugs": {
    "url": "https://github.com/goauthentik/configure-authentik-credentials/issues"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "JEST_JUNIT_CLASSNAME=\"{filepath}\" npx jest --reporters=jest-junit",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "package": "npx rimraf ./dist && npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "npm run package -- --watch",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "all": "npm run format:write && npm run lint && npm run test && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/http-client": "^4.0.0",
    "jwt-decode": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@jest/globals": "^30.2.0",
    "@rollup/plugin-commonjs": "^29.0.1",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.32.1",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "jsonwebtoken": "^9.0.3",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.4.2",
    "rollup": "^4.59.0",
    "ts-jest": "^29.4.6",
    "ts-jest-resolver": "^2.0.1",
    "typescript": "^5.9.3"
  }
}
